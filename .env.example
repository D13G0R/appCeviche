# Ejemplo de variables de entorno para el proyecto
# Copiar este archivo a `.env` y completar valores antes de usar

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# URL de la base de datos en formato DATABASE_URL
# Ejemplo Postgres: postgres://user:password@localhost:5432/dbname
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Email (opcional)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True

# Ruta donde collectstatic colocará los archivos estáticos
STATIC_ROOT=staticfiles

# Puerto para despliegues (Heroku u otros)
PORT=8000
